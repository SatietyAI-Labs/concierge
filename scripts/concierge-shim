#!/home/satiety/.venvs/concierge-hackathon/bin/python3
"""Concierge Claude Code stdio proxy shim — entrypoint wrapper.

Claude Code's MCP configuration references this script path.
Invocation:

    command: /abs/path/to/scripts/concierge-shim

No arguments. Environment:

    CONCIERGE_URL       Concierge HTTP service URL. Default:
                        http://127.0.0.1:8000 (single-process
                        assumption; revisit if Concierge moves
                        off localhost). Read by the N11+ meta-tool
                        handlers; Day 2 framework does not touch
                        this.

Exit codes:

    0   clean shutdown (stdin EOF)
    130 keyboard interrupt
    non-zero otherwise — unhandled exception in the shim; check
                        stderr for the traceback.

All logging goes to stderr. Stdout is reserved for JSON-RPC 2.0
framing; a single contaminating byte kills the Claude Code MCP
client.

## Shebang choice (see commit "fix: shim wrapper must use venv
Python, not system Python")

Absolute path to the venv interpreter. The previous
`#!/usr/bin/env python3` resolved via PATH, which meant Claude
Code's MCP spawn — with no venv activation — hit the system
python3 and raised ModuleNotFoundError on pydantic. The venv's
python3 is a symlink to /usr/bin/python3 on this host; the venv
site-packages discovery relies on the INVOCATION path (argv[0]),
not on PATH resolution. Absolute-shebang invocation keeps that
discovery working regardless of the caller's env.

Machine-specific: the absolute path is tied to this host's venv
location (`/home/satiety/.venvs/concierge-hackathon/`). Porting
to a different machine requires either updating this shebang or
moving to a `pip install -e .` console-scripts entry. The latter
is a post-hackathon cleanup.
"""
import sys
from pathlib import Path

# Resolve the repo root so `adapters.claude_code.shim` imports
# regardless of cwd when Claude Code spawns this wrapper.
_REPO_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(_REPO_ROOT))

from adapters.claude_code.shim import main

if __name__ == "__main__":
    sys.exit(main())
