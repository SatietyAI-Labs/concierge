#!/usr/bin/env python3
"""Concierge Claude Code stdio proxy shim — entrypoint wrapper.

Claude Code's MCP configuration references this script path.
Invocation:

    command: /abs/path/to/scripts/concierge-shim

No arguments. Environment:

    CONCIERGE_URL       Concierge HTTP service URL. Default:
                        http://127.0.0.1:8000 (single-process
                        assumption; revisit if Concierge moves
                        off localhost). Read by the N11+ meta-tool
                        handlers; Day 2 framework does not touch
                        this.

Exit codes:

    0   clean shutdown (stdin EOF)
    130 keyboard interrupt
    non-zero otherwise — unhandled exception in the shim; check
                        stderr for the traceback.

All logging goes to stderr. Stdout is reserved for JSON-RPC 2.0
framing; a single contaminating byte kills the Claude Code MCP
client.
"""
import sys
from pathlib import Path

# Resolve the repo root so `adapters.claude_code.shim` imports
# regardless of cwd when Claude Code spawns this wrapper.
_REPO_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(_REPO_ROOT))

from adapters.claude_code.shim import main

if __name__ == "__main__":
    sys.exit(main())
