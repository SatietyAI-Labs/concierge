# Local databases (dev runtime)
*.db
*.db-journal
*.sqlite
*.sqlite3

# Runtime logs (48h operational-shakedown output may include task
# text and prompt content; keep local, do not commit)
*.log
logs/

# Scratch / throwaway experiments (per CLAUDE.md convention:
# temporary experiments and large reference material Lewie drops
# in for in-session use; never intended as durable artifacts).
planning/scratch/

# Operator-local legacy navigation aids — symlinks pointing to
# external workspaces that exist only on the operator's machine.
# Dangling on any clone; gitignored to keep the public repo clean
# while preserving local operator workflow. Per repo-structure-audit
# 2026-04-29 (Day 8) Surface 1.
_legacy/

# Upgrade-process artifacts whose primary install path resides in
# this repo (per upgrade master-plan §II.5) but whose lifecycle and
# version control belong to ~/satietyai-upgrade/, not here. The
# physical file must exist at this path for the upgrade's rerun
# discipline to work; tracking it in this repo would mix
# upgrade-workspace artifacts with Concierge production code.
scripts/export_agent_memory.py
